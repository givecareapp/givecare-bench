# InvisibleBench Environment Variables
# Copy this file to .env and fill in your API keys

# Required: OpenRouter API key (recommended - unified access to all models)
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Direct provider API keys (if not using OpenRouter)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here

# Optional: Configuration overrides
# Uncomment and modify as needed

# Default timeout for API calls (seconds)
# API_TIMEOUT=120

# Default session approach for multi-session (continuity) scenarios
# SESSION_APPROACH=hybrid_summary

# Default output directory
# OUTPUT_DIR=./results

# Convex publish endpoint (for `bench publish` and --update-leaderboard auto-publish)
# CONVEX_SITE_URL=https://<your-deployment>.convex.site
# BENCH_PUBLISH_KEY=<your publish key>
